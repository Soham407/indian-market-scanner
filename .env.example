# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram Integration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Angel One API Integration
ANGEL_ONE_API_KEY=your-angel-one-api-key
ANGEL_ONE_CLIENT_CODE=your-client-code

# Paper Trading Bot Configuration
# Risk per trade (₹)
BOT_RISK_PER_TRADE=1000

# Daily loss circuit breaker (₹, negative value)
BOT_CIRCUIT_BREAKER_THRESHOLD=-3000

# Volume multiplier for breakout detection
BOT_VOLUME_MULTIPLIER=1.5

# Entry slippage percentage
BOT_ENTRY_SLIPPAGE_PCT=0.0005

# Exit slippage: stops (0.10%) vs targets (0.05%)
BOT_STOP_SLIPPAGE_PCT=0.0010
BOT_TARGET_SLIPPAGE_PCT=0.0005

# Statutory fees and brokerage
BOT_STATUTORY_FEE_PCT=0.0005
BOT_BROKERAGE_PER_LEG=20

# Health check configuration
BOT_STALE_DATA_THRESHOLD_MINUTES=5
BOT_HEARTBEAT_INTERVAL_MINUTES=15
BOT_STALE_INSTRUMENTS_ALERT_THRESHOLD=5

# Market hours (IST)
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
OR_WINDOW_START=09:15
OR_WINDOW_END=09:30
EOD_FLATTEN_TIME=15:15
BREAKOUT_WINDOW_END=15:30

# Feature flags
ENABLE_TELEGRAM_NOTIFICATIONS=true
ENABLE_CIRCUIT_BREAKER=true
ENABLE_HEALTH_CHECK=true

# Development
NODE_ENV=production
LOG_LEVEL=info
